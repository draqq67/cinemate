cat > ~/Desktop/cinemate/.gitignore << 'EOF'
# Environment
.env
.env.test
.env.local
*.env

# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/

# Build output
dist/
build/
*.egg-info/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Docker volumes (never commit these)
pg_data/
jellyfin_config/
jellyfin_cache/

# Test artifacts
junit.xml
coverage/
EOF
CLAUDE.md
FEATURES.md

cookies.txt

# ML data & trained models (large files, not for git)
ml/notebooks/data/
ml/notebooks/models/
ml/data/*.parquet
ml/models/*.pkl
docs/
testing/
testing/results/
exemple_documentatii
.claude
