{
  "openapi": "3.0.3",
  "info": {
    "title": "Cinemate API",
    "description": "Full-stack movie streaming and social recommendation platform. Catalog data from PostgreSQL; rich movie detail, cast, and trailers fetched live from TMDB API.",
    "version": "2.0.0"
  },
  "servers": [
    { "url": "/api", "description": "Reverse-proxied through Nginx" }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "accessToken",
        "description": "HttpOnly JWT cookie set on login/register. Access token TTL 15 min; refresh token 7 days."
      }
    },
    "schemas": {
      "Movie": {
        "type": "object",
        "properties": {
          "tmdb_id":      { "type": "integer" },
          "title":        { "type": "string" },
          "year":         { "type": "integer" },
          "runtime":      { "type": "integer", "description": "Minutes" },
          "poster_path":  { "type": "string" },
          "backdrop_path":{ "type": "string" },
          "overview":     { "type": "string", "description": "Fetched live from TMDB" },
          "tagline":      { "type": "string", "description": "Fetched live from TMDB" },
          "vote_average": { "type": "number" },
          "vote_count":   { "type": "integer" },
          "avg_rating":   { "type": "number", "description": "Community average score (1–10)" },
          "rating_count": { "type": "integer" },
          "popularity":   { "type": "number" },
          "jellyfin_id":  { "type": "string", "nullable": true },
          "inDb":         { "type": "boolean", "description": "True if movie is in local catalog; false = TMDB-only" },
          "genres":       { "type": "array", "items": { "type": "string" } },
          "keywords":     { "type": "array", "items": { "type": "string" }, "description": "From TMDB" },
          "status":       { "type": "string" },
          "original_title":    { "type": "string" },
          "original_language": { "type": "string" },
          "budget":   { "type": "integer" },
          "revenue":  { "type": "integer" },
          "imdb_id":  { "type": "string" },
          "production_companies": {
            "type": "array",
            "items": { "type": "object", "properties": { "id": { "type": "integer" }, "name": { "type": "string" }, "logo_path": { "type": "string" } } }
          },
          "countries": {
            "type": "array",
            "items": { "type": "object", "properties": { "iso_code": { "type": "string" }, "name": { "type": "string" } } }
          }
        }
      },
      "CastMember": {
        "type": "object",
        "properties": {
          "id":           { "type": "integer" },
          "name":         { "type": "string" },
          "character":    { "type": "string" },
          "profile_path": { "type": "string" },
          "cast_order":   { "type": "integer" }
        }
      },
      "CrewMember": {
        "type": "object",
        "properties": {
          "id":           { "type": "integer" },
          "name":         { "type": "string" },
          "job":          { "type": "string" },
          "department":   { "type": "string" },
          "profile_path": { "type": "string" }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id":          { "type": "string", "format": "uuid" },
          "body":        { "type": "string" },
          "created_at":  { "type": "string", "format": "date-time" },
          "parent_id":   { "type": "string", "format": "uuid", "nullable": true },
          "username":    { "type": "string" },
          "user_id":     { "type": "string", "format": "uuid" },
          "user_rating": { "type": "integer", "nullable": true }
        }
      },
      "Trailer": {
        "type": "object",
        "properties": {
          "key":  { "type": "string", "description": "YouTube video ID" },
          "name": { "type": "string" }
        }
      },
      "Subtitle": {
        "type": "object",
        "properties": {
          "id":         { "type": "string", "format": "uuid" },
          "language":   { "type": "string" },
          "label":      { "type": "string" },
          "username":   { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id":         { "type": "string", "format": "uuid" },
          "email":      { "type": "string" },
          "username":   { "type": "string" },
          "role":       { "type": "string", "enum": ["user", "admin"] },
          "avatar_url": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "List": {
        "type": "object",
        "properties": {
          "id":          { "type": "string", "format": "uuid" },
          "title":       { "type": "string" },
          "description": { "type": "string", "nullable": true },
          "is_public":   { "type": "boolean" },
          "username":    { "type": "string" },
          "movie_count": { "type": "integer" },
          "created_at":  { "type": "string", "format": "date-time" }
        }
      },
      "DMMessage": {
        "type": "object",
        "properties": {
          "id":             { "type": "string", "format": "uuid" },
          "sender_id":      { "type": "string", "format": "uuid" },
          "sender_username":{ "type": "string" },
          "body":           { "type": "string", "nullable": true },
          "movie_tmdb_id":  { "type": "integer", "nullable": true },
          "movie_title":    { "type": "string", "nullable": true },
          "movie_poster":   { "type": "string", "nullable": true },
          "created_at":     { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["email","username","password"], "properties": { "email": { "type": "string" }, "username": { "type": "string" }, "password": { "type": "string" } } } } }
        },
        "responses": {
          "201": { "description": "Registered — sets HttpOnly JWT access + refresh token cookies" },
          "409": { "description": "Email or username already taken" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["email","password"], "properties": { "email": { "type": "string" }, "password": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "OK — sets HttpOnly JWT cookies" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout — clears both JWT cookies",
        "responses": { "200": { "description": "Cookies cleared" } }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current authenticated user",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "User object", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "401": { "description": "Not authenticated" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Rotate refresh token — issues new access + refresh token pair",
        "responses": { "200": { "description": "New tokens set in cookies" }, "401": { "description": "Refresh token missing or invalid" } }
      }
    },

    "/movies": {
      "get": {
        "tags": ["Movies"],
        "summary": "Browse catalog movies",
        "parameters": [
          { "name": "search",  "in": "query", "schema": { "type": "string" }, "description": "Title full-text search (trigram index)" },
          { "name": "genre",   "in": "query", "schema": { "type": "string" }, "description": "Genre name filter" },
          { "name": "year",    "in": "query", "schema": { "type": "integer" } },
          { "name": "sort",    "in": "query", "schema": { "type": "string", "enum": ["popularity","rating","newest","oldest","title","vote_count"] } },
          { "name": "page",    "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit",   "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "Paginated movies", "content": { "application/json": { "schema": { "type": "object", "properties": { "movies": { "type": "array", "items": { "$ref": "#/components/schemas/Movie" } }, "total": { "type": "integer" }, "page": { "type": "integer" }, "pages": { "type": "integer" } } } } } }
        }
      }
    },
    "/movies/genres": {
      "get": {
        "tags": ["Movies"],
        "summary": "List all genres with movie counts",
        "responses": { "200": { "description": "{ genres: [{ id, name, count }] }" } }
      }
    },
    "/movies/search/tmdb": {
      "get": {
        "tags": ["Movies"],
        "summary": "Search TMDB directly — returns inDb flag per result",
        "parameters": [
          { "name": "q", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "{ movies: [{ tmdb_id, title, year, poster_path, inDb }] }" } }
      }
    },
    "/movies/tmdb/popular": {
      "get": {
        "tags": ["Movies"],
        "summary": "TMDB live popular movies (20 results) — used by HomePage",
        "responses": { "200": { "description": "{ movies: [{ tmdb_id, title, year, poster_path, vote_average }] }" } }
      }
    },
    "/movies/tmdb/top_rated": {
      "get": {
        "tags": ["Movies"],
        "summary": "TMDB live top-rated movies",
        "responses": { "200": { "description": "{ movies: [{ tmdb_id, title, year, poster_path, vote_average }] }" } }
      }
    },
    "/movies/tmdb/now_playing": {
      "get": {
        "tags": ["Movies"],
        "summary": "TMDB live now-playing movies",
        "responses": { "200": { "description": "{ movies: [{ tmdb_id, title, year, poster_path, vote_average }] }" } }
      }
    },
    "/movies/subtitles/search": {
      "get": {
        "tags": ["Movies"],
        "summary": "Search OpenSubtitles (returns [] if OPENSUBTITLES_KEY not set)",
        "parameters": [
          { "name": "tmdb_id",   "in": "query", "schema": { "type": "integer" } },
          { "name": "languages", "in": "query", "schema": { "type": "string", "default": "en" } },
          { "name": "query",     "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "{ subtitles: [] }" } }
      }
    },
    "/movies/subtitles/download": {
      "post": {
        "tags": ["Movies"],
        "summary": "Proxy OpenSubtitles download link",
        "security": [{ "cookieAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "file_id": { "type": "integer" } } } } } },
        "responses": { "200": { "description": "{ link: string }" } }
      }
    },
    "/movies/{tmdbId}": {
      "get": {
        "tags": ["Movies"],
        "summary": "Full movie detail — DB data + live TMDB (cast, crew, trailers, reviews, keywords). Falls back to TMDB-only if not in catalog (inDb: false).",
        "parameters": [{ "name": "tmdbId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Movie detail with cast, crew, comments, trailers", "content": { "application/json": { "schema": { "type": "object", "properties": { "movie": { "$ref": "#/components/schemas/Movie" }, "cast": { "type": "array", "items": { "$ref": "#/components/schemas/CastMember" } }, "crew": { "type": "array", "items": { "$ref": "#/components/schemas/CrewMember" } }, "tmdbReviews": { "type": "array", "items": { "type": "object" } }, "comments": { "type": "array", "items": { "$ref": "#/components/schemas/Comment" } }, "trailers": { "type": "array", "items": { "$ref": "#/components/schemas/Trailer" } } } } } } },
          "404": { "description": "Movie not found on TMDB" }
        }
      }
    },
    "/movies/{tmdbId}/rate": {
      "post": {
        "tags": ["Movies"],
        "summary": "Rate a movie (1–10); triggers avg_rating DB update",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "tmdbId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "score": { "type": "integer", "minimum": 1, "maximum": 10 } } } } } },
        "responses": { "200": { "description": "{ avg_rating, rating_count }" } }
      }
    },
    "/movies/{tmdbId}/my-rating": {
      "get": {
        "tags": ["Movies"],
        "summary": "Get your rating for this movie",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "tmdbId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "{ score: number | null }" } }
      }
    },
    "/movies/{tmdbId}/comments": {
      "post": {
        "tags": ["Movies"],
        "summary": "Post a comment (supports parent_id for threaded replies)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "tmdbId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["body"], "properties": { "body": { "type": "string" }, "parent_id": { "type": "string", "format": "uuid", "nullable": true } } } } } },
        "responses": { "201": { "description": "Comment created" } }
      }
    },
    "/movies/{tmdbId}/watchlist": {
      "get": {
        "tags": ["Movies"],
        "summary": "Check if movie is in your watchlist",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "tmdbId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "{ inWatchlist: boolean }" } }
      },
      "post": {
        "tags": ["Movies"],
        "summary": "Toggle movie in/out of watchlist",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "tmdbId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "{ added: boolean }" } }
      }
    },
    "/movies/{tmdbId}/stream-url": {
      "get": {
        "tags": ["Movies"],
        "summary": "Get Jellyfin stream URL — detects codecs, returns direct MP4 or HLS + subtitle tracks",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "tmdbId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "{ streamUrl, jellyfinId, type: 'mp4'|'hls', transcoding, subtitles[] }" },
          "404": { "description": "Movie not in catalog or no Jellyfin link" }
        }
      }
    },
    "/movies/{tmdbId}/progress": {
      "post": {
        "tags": ["Movies"],
        "summary": "Save watch progress (called every 30s by VideoPlayer)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "tmdbId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "progress_s": { "type": "integer", "description": "Seconds watched" } } } } } },
        "responses": { "200": { "description": "{ ok: true }" } }
      }
    },
    "/movies/{tmdbId}/trailers": {
      "get": {
        "tags": ["Movies"],
        "summary": "YouTube trailers from TMDB video endpoint",
        "parameters": [{ "name": "tmdbId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "[{ key, name }] — key is YouTube video ID" } }
      }
    },
    "/movies/{tmdbId}/user-subtitles": {
      "get": {
        "tags": ["Movies"],
        "summary": "List community-uploaded subtitle tracks for a movie",
        "parameters": [{ "name": "tmdbId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "{ subtitles: Subtitle[] }" } }
      }
    },
    "/movies/{tmdbId}/subtitle": {
      "post": {
        "tags": ["Movies"],
        "summary": "Upload subtitle (SRT or VTT); SRT auto-converted to VTT on server",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "tmdbId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["content","language","label"], "properties": { "content": { "type": "string" }, "language": { "type": "string", "example": "en" }, "label": { "type": "string", "example": "English SDH" } } } } } },
        "responses": { "201": { "description": "Subtitle saved" } }
      }
    },
    "/movies/{tmdbId}/subtitle/{subtitleId}": {
      "get": {
        "tags": ["Movies"],
        "summary": "Serve subtitle file as text/vtt",
        "parameters": [
          { "name": "tmdbId",     "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "subtitleId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "VTT file content", "content": { "text/vtt": { "schema": { "type": "string" } } } } }
      }
    },

    "/people/{personId}": {
      "get": {
        "tags": ["People"],
        "summary": "Actor/director detail — live TMDB proxy (not stored in DB)",
        "parameters": [{ "name": "personId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "{ name, biography, birthday, profile_path, photos[], movies[], directed[] }" } }
      }
    },

    "/users/me/stats": {
      "get": {
        "tags": ["Users"],
        "summary": "Your profile stats",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "{ watched, rated, wishlist, avgRating }" } }
      }
    },
    "/users/me/history": {
      "get": {
        "tags": ["Users"],
        "summary": "Your watch history with progress_s per movie",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "Array of movies with progress_s" } }
      }
    },
    "/users/me/favourites": {
      "get": {
        "tags": ["Users"],
        "summary": "Movies you rated ≥ 8",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "Array of movies" } }
      }
    },
    "/users/me/wishlist": {
      "get": {
        "tags": ["Users"],
        "summary": "Your watchlist",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "Array of movies" } }
      }
    },
    "/users/me/comments": {
      "get": {
        "tags": ["Users"],
        "summary": "Your comments with movie titles",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "Array of comments" } }
      }
    },
    "/users/me/ratings": {
      "get": {
        "tags": ["Users"],
        "summary": "All your movie ratings",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "Array of { tmdb_id, title, score, created_at }" } }
      }
    },
    "/users/me/preferences": {
      "get": {
        "tags": ["Users"],
        "summary": "Get saved preferences (moods, duration, context from Discover wizard)",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "{ preferences: object | null }" } }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Save preferences as JSONB",
        "security": [{ "cookieAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": { "200": { "description": "Saved" } }
      }
    },
    "/users/search": {
      "get": {
        "tags": ["Users"],
        "summary": "Search users by username (case-insensitive partial match)",
        "parameters": [{ "name": "q", "in": "query", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Array of { id, username, avatar_url, follower_count }" } }
      }
    },

    "/activity/feed": {
      "get": {
        "tags": ["Activity"],
        "summary": "Feed of people you follow — ratings, comments, watch events",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } }],
        "responses": { "200": { "description": "Array of activity events with type, user, movie, timestamp" } }
      }
    },
    "/activity/follow/{userId}": {
      "get": {
        "tags": ["Activity"],
        "summary": "Check if you follow a user",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "{ following: boolean }" } }
      },
      "post": {
        "tags": ["Activity"],
        "summary": "Toggle follow/unfollow a user",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "{ following: boolean }" } }
      }
    },
    "/activity/users/{userId}/followers": {
      "get": {
        "tags": ["Activity"],
        "summary": "List a user's followers",
        "parameters": [{ "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Array of { id, username, avatar_url }" } }
      }
    },
    "/activity/users/{userId}/following": {
      "get": {
        "tags": ["Activity"],
        "summary": "List who a user follows",
        "parameters": [{ "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Array of { id, username, avatar_url }" } }
      }
    },
    "/activity/users/{userId}/profile": {
      "get": {
        "tags": ["Activity"],
        "summary": "Public user profile — stats, recent ratings, follow counts",
        "parameters": [{ "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "{ username, created_at, watched, rated, avgRating, followers, following, recent_ratings[] }" } }
      }
    },
    "/activity/analytics": {
      "get": {
        "tags": ["Activity"],
        "summary": "Fast personal analytics — totals, streak, by-day, by-hour (~200ms)",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "{ movies_watched, total_minutes, avg_rating, rated_count, wishlist_count, streak, genres[], by_day[], by_hour[], recent_watched[], recent_ratings[] }" } }
      }
    },
    "/activity/analytics/charts": {
      "get": {
        "tags": ["Activity"],
        "summary": "Deferred chart data — rating distribution, decade bars, monthly, genre avg scores, heatmap",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "{ rating_dist[], by_decade[], by_month[], genre_ratings[], top_rated[], by_date[] }" } }
      }
